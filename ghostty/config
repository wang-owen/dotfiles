# ---Appearance---

theme = Gruvbox Dark
background-blur = true

font-family = Iosevka Term
font-size = 16
font-feature = -calt

cursor-style = block
shell-integration-features = no-cursor
mouse-hide-while-typing = true

# ---macOS---

macos-titlebar-style = tabs
macos-icon = glass
macos-window-buttons = hidden

# Use Option key as Alt (needed for terminal shortcuts)
macos-option-as-alt = true

# ---Keybindings---

# Global hotkey to toggle Ghostty visibility
keybind = global:alt+`=toggle_visibility
